# =============================================
# AI Agent Servisi (.env) — ai-agent/ klasörüne kopyala
# =============================================

# Gemini API Key — sadece AI agent için
# https://aistudio.google.com adresinden ücretsiz alınır
AGENT_GEMINI_API_KEY=your_agent_gemini_key_here

# MySQL Veritabanı bağlantısı
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=root
DB_PASSWORD=your_db_password_here

# JWT Secret — Yaren'in Spring Boot'undaki secret ile AYNI olmali
JWT_SECRET=your_jwt_secret_here
